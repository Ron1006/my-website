'use client';

import React, { useState } from 'react';
import Image from 'next/image';
import Link from 'next/link';

// --- 作品集数据 (补充到了8个，用来测试分页) ---
const projects = [
  { id: 1, title: "Del Tutto", category: "UI/UX Design and Development", image: "/images/Insight1.png", link: "#" },
  { id: 2, title: "E-Commerce App", category: "Mobile UI Design", image: "/projects/Project1.png", link: "#" },
  { id: 3, title: "SaaS Dashboard", category: "Web Application", image: "/projects/Project1.png", link: "#" },
  { id: 4, title: "Gaming Portal", category: "Unity & Next.js", image: "/projects/Project1.png", link: "#" },
  { id: 5, title: "Fintech Platform", category: "UI/UX Design", image: "/projects/Project1.png", link: "#" },
  { id: 6, title: "Healthcare App", category: "React Native", image: "/projects/Project1.png", link: "#" },
  { id: 7, title: "Real Estate Website", category: "Web Development", image: "/projects/Project1.png", link: "#" },
  { id: 8, title: "Social Media Dashboard", category: "Front-end Dev", image: "/projects/Project1.png", link: "#" },
];

export default function Portfolio() {
  // --- 分页逻辑 ---
  const [currentPage, setCurrentPage] = useState(1);
  const projectsPerPage = 4; // 每页显示 4 个项目 (正好 2行 x 2列)

  // 计算总页数
  const totalPages = Math.ceil(projects.length / projectsPerPage);

  // 截取当前页需要显示的数据
  const indexOfLastProject = currentPage * projectsPerPage;
  const indexOfFirstProject = indexOfLastProject - projectsPerPage;
  const currentProjects = projects.slice(indexOfFirstProject, indexOfLastProject);

  return (
    <section id="portfolio" className="w-full py-24 bg-[#050505] flex justify-center min-h-screen">
      <div className="max-w-7xl mx-auto px-6 w-full flex flex-col items-center">

        {/* --- 页面标题 --- */}
        <div className="text-center mb-16 md:mb-24 mt-8">
          <h1 className="text-4xl md:text-6xl font-bold tracking-tight text-white">
            Portfolio
          </h1>
        </div>

        {/* --- 标准网格布局 (固定2列，取消瀑布流) --- */}
        <div className="grid grid-cols-2 md:grid-cols-2 gap-12 md:gap-16 w-full mb-16">
          {currentProjects.map((project, index) => (
            <Link
              href={project.link}
              key={project.id}
              className="group flex flex-col w-full"
            >
              {/* 图片容器 */}
              <div className="relative w-full rounded-2xl overflow-hidden mb-6 bg-[#111]">
                <Image
                  src={project.image}
                  alt={project.title}
                  fill
                  className="w-full h-auto object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                  priority={index < 2}
                />
              </div>

              {/* 文本内容 */}
              <div className="flex flex-col items-start text-left">
                <h2 className="text-2xl md:text-3xl font-bold mb-2 text-white group-hover:text-[#ff8a00] transition-colors duration-300">
                  {project.title}
                </h2>
                <p className="text-gray-400 text-base md:text-lg tracking-wide">
                  {project.category}
                </p>
              </div>
            </Link>
          ))}
        </div>

        {/* --- 分页按钮组件 --- */}
        {totalPages > 1 && (
          <div className="flex justify-center items-center gap-4 mt-8">
            {Array.from({ length: totalPages }).map((_, index) => {
              const pageNumber = index + 1;
              return (
                <button
                  key={pageNumber}
                  onClick={() => {
                    setCurrentPage(pageNumber);
                    // 点击分页后，自动平滑滚动回顶部
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                  }}
                  className={`w-12 h-12 flex items-center justify-center rounded-full transition-all duration-300 text-sm md:text-base
                    ${currentPage === pageNumber
                      ? 'border border-white/20 text-white' // 当前页：显示白色圆圈边框
                      : 'text-gray-500 hover:text-white hover:bg-white/5' // 非当前页：灰色，悬浮变白
                    }`}
                >
                  {pageNumber}
                </button>
              );
            })}
          </div>
        )}

      </div>
    </section>
  );
}